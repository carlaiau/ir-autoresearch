OPENAI_API_KEY=

# Enable the OpenAI-backed reranker in eval/benchmark wrappers.
# Supported values: off, mono, mono_duo
JASSJR_OPENAI_RERANK_MODE=mono

# Default OpenAI model selections for issue #30.
JASSJR_OPENAI_MONO_MODEL=gpt-5-mini
JASSJR_OPENAI_DUO_MODEL=gpt-5-mini

# Stage sizes and truncation budget.
JASSJR_OPENAI_MONO_DOCS=85
JASSJR_OPENAI_DUO_DOCS=10
JASSJR_OPENAI_DOC_WORDS=220

# Optional tri-source dense retrieval scaffold for issue #38.
# Supported values: off, openai
JASSJR_SEMANTIC_MODE=off
JASSJR_SEMANTIC_MODEL=text-embedding-3-small
JASSJR_SEMANTIC_DIMENSIONS=512
JASSJR_SEMANTIC_DOC_WORDS=220
JASSJR_SEMANTIC_BATCH_SIZE=64
JASSJR_SEMANTIC_TOPK=1000

# Weighted reciprocal rank fusion settings for the tri-source scaffold.
JASSJR_FUSION_RRF_K=60
JASSJR_FUSION_WEIGHT_BM25=0.45
JASSJR_FUSION_WEIGHT_RM3=0.35
JASSJR_FUSION_WEIGHT_DENSE=0.20
JASSJR_FUSION_BM25_TOPK=250
JASSJR_FUSION_RM3_TOPK=250
JASSJR_FUSION_DENSE_TOPK=250

# Prompt/cache controls.
JASSJR_OPENAI_PROMPT_VERSION=openai-rerank-v2
JASSJR_OPENAI_CACHE_DIR=.cache/openai-rerank
JASSJR_OPENAI_CACHE_ONLY=0
